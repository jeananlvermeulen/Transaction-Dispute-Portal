{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST:-.};Database=${DB_NAME:-TransactionDisputePortal};User Id=${DB_USER};Password=${DB_PASSWORD};Trusted_Connection=${DB_TRUSTED_CONNECTION:-true};"
  },
  "AWS": {
    "Region": "${AWS_REGION:-us-east-1}"
  }
}
